{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": "src",
		"declaration": false,
		"sourceMap": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["chrome"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}
