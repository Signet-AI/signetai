---
const links = [
	{
		label: "Architecture",
		href: "/docs/architecture/",
		blurb: "Full technical architecture — packages, data flow, and system design.",
	},
	{
		label: "Memory Pipeline",
		href: "/docs/pipeline/",
		blurb: "Deep dive into extraction, decision, graph, and retention stages.",
	},
	{
		label: "Platform Integrations",
		href: "/docs/harnesses/",
		blurb: "How connectors work across Claude Code, OpenCode, OpenClaw, and more.",
	},
	{
		label: "All Documentation",
		href: "/docs/",
		blurb: "Setup guides, API reference, CLI commands, and everything else.",
	},
];
---

<section id="dive-deeper" class="container" style="border-top: 1px solid var(--color-border)">
  <div class="section-header reveal">
    <div class="crosshair"></div>
    <span class="section-label">Dive Deeper</span>
    <span class="section-index">06 / 06</span>
  </div>

  <div class="arch-cta-grid reveal">
    {links.map((link) => (
      <a href={link.href} class="arch-cta-card">
        <h3>{link.label}</h3>
        <p>{link.blurb}</p>
        <span class="arch-cta-arrow">Read more &#8594;</span>
      </a>
    ))}
  </div>
</section>
